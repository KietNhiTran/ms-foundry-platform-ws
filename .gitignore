.venv/
venv/
__pycache__/
.pytest_cache/
*.py[cod]
*.pyo

# Build and packaging artifacts
build/
dist/
*.egg-info/

# .NET build outputs (Module 11 pro-code)
bin/
obj/

# Environment files
.env
.env.*

# Module 11 pro-code — local appsettings contain Foundry endpoints, subscription
# IDs, and App Insights connection strings. Copy appsettings.example.json →
# appsettings.json and fill in your own values.
modules/11-pro-code/src/ContosoEstimator/appsettings.json
modules/11-pro-code/src/ContosoEstimator.Web/appsettings.json

# Module 03 Track 2 RLS app — local appsettings hold the Entra client secret,
# tenant/client/group IDs and SQL/Search endpoints. Copy appsettings.example.json
# → appsettings.json and fill in your own values (secret via `dotnet user-secrets`).
modules/03-agentic-rag/src/track2-identity-rls/appsettings.json

# Module 13 network isolation — local sparse checkout of the official Foundry
# sample (Template 15). Fetched by infra/deploy.ps1; not committed.
modules/13-network-data-protection/infra/.template-15/

# Editor and OS artifacts
.vscode/
.idea/
.DS_Store
Thumbs.db

