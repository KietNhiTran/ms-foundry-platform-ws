# ============================================================
# Contoso Estimator - Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# Foundry project endpoint
# Format: https://<resource-name>.services.ai.azure.com/api/projects/<project-name>
FOUNDRY_PROJECT_ENDPOINT=https://your-resource.services.ai.azure.com/api/projects/your-project

# Model deployment name (default: gpt-4.1)
FOUNDRY_MODEL_DEPLOYMENT_NAME=gpt-4.1

# Agent name for steps 2-8
FOUNDRY_AGENT_NAME=contoso-estimator-advisor

# Application Insights connection string (for Step 6 - Tracing)
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=your-key;IngestionEndpoint=https://your-region.in.applicationinsights.azure.com/

# Foundry IQ knowledge base endpoint (for Step 3)
FOUNDRY_IQ_ENDPOINT=https://your-resource.services.ai.azure.com/api/projects/your-project/knowledge-bases/your-kb

# OpenAPI tool endpoint (for Step 5)
OPENAPI_TOOL_ENDPOINT=https://your-api.azurewebsites.net/openapi.json
