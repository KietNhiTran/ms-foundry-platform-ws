{
  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "TenantId": "<your-tenant-id>",
    "ClientId": "<your-app-client-id>",
    "ClientSecret": "",
    "CallbackPath": "/signin-oidc"
  },
  "Search": {
    "Endpoint": "https://<your-search-service>.search.windows.net",
    "KnowledgeBaseName": "sql-knowledge-base",
    "KnowledgeSourceName": "<your-knowledge-source-name>",
    "SecuredIndexName": "rate-library-secured",
    "MaxOutputDocuments": 50
  },
  "Sql": {
    "ConnectionString": "Server=tcp:<sql-server>.database.windows.net,1433;Database=<sql-db>;Authentication=Active Directory Default;Encrypt=True;"
  },
  "Groups": {
    "grp-estimating-nsw": "<nsw-group-object-id>",
    "grp-estimating-vic": "<vic-group-object-id>"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
